# ── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── Branding ──────────────────────────────────────────────────────────────────
APP_NAME=Taskify

# ── Features ──────────────────────────────────────────────────────────────────
# Set to false to restrict ticket submission and status views to logged-in users
PUBLIC_TICKETS=true

# ── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite:///taskify.db

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=false
# MAIL_USERNAME=
# MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@taskify.local
# MAIL_SUPPRESS_SEND=false

# ── i18n ─────────────────────────────────────────────────────────────────────
# BABEL_DEFAULT_LOCALE=en

# ── Inbound e-mail via Microsoft Graph API (Microsoft 365) ────────────────────
# Preferred for M365 / Exchange Online (Basic Auth is disabled by Microsoft).
# 1. In Azure AD → App registrations → New registration (any name, single-tenant)
# 2. API permissions → Add → Microsoft Graph → Application → Mail.Read → Grant admin consent
# 3. Certificates & secrets → New client secret → copy value to AZURE_CLIENT_SECRET
# 4. Overview → copy Application (client) ID → AZURE_CLIENT_ID
#              copy Directory (tenant) ID  → AZURE_TENANT_ID
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_SECRET=your-client-secret-value
# GRAPH_MAILBOX=support@example.com
# GRAPH_POLL_INTERVAL=60

# ── Inbound e-mail via IMAP (optional, non-M365) ──────────────────────────────
# Emails received in this mailbox are automatically turned into support tickets.
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USE_SSL=true
# IMAP_USER=support@weitkamper.de
# IMAP_PASSWORD=your-mailbox-password
# IMAP_POLL_INTERVAL=60

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_ORG=my-organisation
# GITHUB_TOKEN=ghp_your_personal_access_token
